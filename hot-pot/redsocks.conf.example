base {
    log_debug = off;
    log_info = on;
    log = "syslog:daemon";
    daemon = on;
    redirector = iptables;
}

/*
 * Take TCP redirected by nft to 127.0.0.1:12345
 * and tunnel it through the local HTTP CONNECT proxy at 127.0.0.1:6152
 * (which is the surge-tunnel entry).
 *
 * If you switch surge-tunnel to a SOCKS5 backend, change type to socks5.
 */
redsocks {
    /*
     * Listen on 0.0.0.0 (NOT 127.0.0.1)! nft `redirect to :12345`
     * rewrites the destination IP to the in-bound interface's primary IP
     * (10.42.0.1 for wlp0s20f3), so a 127.0.0.1-only bind would refuse.
     * The hotspot_proxy nft `input` chain restricts who can hit :12345.
     */
    local_ip   = 0.0.0.0;
    local_port = 12345;

    ip   = 127.0.0.1;
    port = 6152;
    type = http-connect;
}
